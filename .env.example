# Stripe publishable key (starts with pk_test_ or pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Stripe Price IDs (create these in your Stripe Dashboard > Products)
VITE_STRIPE_PRICE_BASIC=price_xxx
VITE_STRIPE_PRICE_PROFESSIONAL=price_xxx
VITE_STRIPE_PRICE_PREMIUM=price_xxx
VITE_STRIPE_PRICE_MONTHLY=price_xxx
